# Copy this file to .env.local for local development.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional order email via Google Workspace Gmail SMTP.
GOOGLE_WORKSPACE_SMTP_HOST=smtp.gmail.com
GOOGLE_WORKSPACE_SMTP_PORT=465
GOOGLE_WORKSPACE_SMTP_SECURE=true
GOOGLE_WORKSPACE_SMTP_TIMEOUT_MS=15000
GOOGLE_WORKSPACE_SMTP_USER=info@royalislabs.com
GOOGLE_WORKSPACE_SMTP_PASS=
ORDER_FROM_EMAIL=Royalis Lab <info@royalislabs.com>
ORDER_REPLY_TO_EMAIL=info@royalislabs.com
ORDER_BUSINESS_EMAIL=info@royalislabs.com

# Manual e-transfer instructions.
ETRANSFER_PAYEE=Royalis Lab
ETRANSFER_EMAIL=info@royalislabs.com
